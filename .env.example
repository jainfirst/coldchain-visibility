# Copy to .env and fill in. .env is gitignored — never commit real values.
# Everything here is OPTIONAL: with nothing set, the app still runs fully off the
# bundled Tive snapshot (live screen) and the CSV (fleet view).

# FedEx Track API (OAuth client-credentials).
# Absent -> the FedEx panel shows "unavailable"; the rest of the app works.
FEDEX_CLIENT_ID=
FEDEX_CLIENT_SECRET=

# Tive sensor API. Provide EITHER a vendor bearer token (valid ~1h) OR OAuth creds.
# Absent -> the live screen serves the bundled snapshot, labelled "NOT LIVE".
TIVE_BEARER_TOKEN=
TIVE_CLIENT_ID=
TIVE_CLIENT_SECRET=

# Optional overrides (defaults shown):
# TIVE_ACCOUNT_ID=6849
# TIVE_TEMP_UNIT=F          # sensor unit; converted to °C on ingest
# TEMP_CLASS=CRT            # default product temperature class
# TRACKING_NUMBER=885364545720
